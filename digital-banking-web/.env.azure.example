# The frontend is built into digital-banking-platform/src/main/resources/static
# and served by the same Spring Boot app/Azure App Service as the API, so the
# default same-origin base URL below (also the default in src/config/env.ts)
# is correct for production and normally does not need to be overridden.
VITE_API_BASE_URL=/api

# Only set this to a different origin if the frontend is ever hosted separately
# from the backend (e.g. a standalone static site pointing at another App Service).
# VITE_API_BASE_URL=https://your-api.azurewebsites.net/api
