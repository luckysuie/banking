# Copy these as Application Settings on Azure App Service (Java API).
# Do NOT put SQL URL / username / password here — they come from Key Vault at runtime.

SPRING_PROFILES_ACTIVE=azure
PORT=8080
WEBSITES_PORT=8080

# Key Vault (system-assigned managed identity must have "Key Vault Secrets User")
AZURE_KEYVAULT_ENDPOINT=https://your-keyvault-name.vault.azure.net/

# Key Vault secret names expected by application-azure.yml:
#   sql-jdbc-url       → spring property sql.jdbc.url
#   sql-admin-username → spring property sql.admin.username
#   sql-admin-password → spring property sql.admin.password
#
# Example value for sql-jdbc-url:
# jdbc:sqlserver://YOUR_SERVER.database.windows.net:1433;database=digitalbanking;encrypt=true;trustServerCertificate=false;hostNameInCertificate=*.database.windows.net;loginTimeout=30;

# HTTP Basic auth (override defaults in production)
APP_SECURITY_CUSTOMER_USERNAME=customer
APP_SECURITY_CUSTOMER_PASSWORD=changeme-customer
APP_SECURITY_ADMIN_USERNAME=admin
APP_SECURITY_ADMIN_PASSWORD=changeme-admin

# Optional
APP_DATA_INITIALIZE=true
APP_CORS_ALLOWED_ORIGINS=https://your-web.azurewebsites.net
